<div id="top" class="top-anchor" aria-hidden="true"></div>

<section class="room-hero" aria-label="Homepage intro">
  <h1 class="room-hero-wordmark">ARCHIMMERSION</h1>
</section>

<section class="room-stage" data-room-scene aria-label="Interactive room metaphor">
  <div class="room-stage-headline" aria-hidden="true" data-i18n="headline">Explore the room.</div>
  <div class="room-svg-wrap">
    <svg
      class="room-svg"
      viewBox="0 0 1000 620"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label="Architectural room with three interactive objects"
    >
      <g id="room-background" class="room-lines">
        <path d="M220 130H780" />
        <path d="M220 130L140 90" />
        <path d="M780 130L860 90" />
        <path d="M220 420H780" />
        <path d="M220 420L140 500" />
        <path d="M780 420L860 500" />

        <path d="M320 322H700L760 360H260Z" />
        <path d="M260 360V470" />
        <path d="M760 360V470" />
        <path d="M320 322V442" />
        <path d="M700 322V442" />
      </g>

      <g
        id="hotspot-window"
        class="room-hotspot"
        role="button"
        tabindex="0"
        aria-label="Open Lighting section"
        aria-controls="pillar-panel"
        aria-pressed="false"
        data-panel-title="LIGHTING"
        data-panel-points="Light as a design material|Atmosphere-led interior strategy|Spatial sequence and proportion|Calm, sensorial architectural thinking"
        data-panel-cta-label="Open Lighting"
        data-panel-cta-href="{{ '/design/' | toBaseRelative }}"
      >
        <rect class="hotspot-hitarea" x="232" y="152" width="196" height="156" />
        <rect class="hotspot-shape" x="250" y="170" width="160" height="120" />
        <path class="hotspot-shape" d="M330 170V290" />
        <path class="hotspot-shape" d="M250 230H410" />
        <g class="hotspot-tooltip" aria-hidden="true">
          <rect class="hotspot-tooltip-bg" x="282" y="140" width="96" height="24" rx="12" ry="12" />
          <text class="hotspot-tooltip-text" x="330" y="152" text-anchor="middle" dominant-baseline="middle" data-tooltip-text>
            Lighting
          </text>
        </g>
      </g>

      <g
        id="hotspot-laptop"
        class="room-hotspot"
        role="button"
        tabindex="0"
        aria-label="Open Communication section"
        aria-controls="pillar-panel"
        aria-pressed="false"
        data-panel-title="COMMUNICATION"
        data-panel-body="Immersive Architectural Communication for professional websites and magazines. Beyond vision. We capture architecture as it is experienced. Through advanced imaging technologies and an expert eye for atmosphere, we translate spaces into immersive experiences — faithful, sensory, and atmospheric. Using cutting-edge tools — from 360° immersive environments to high-fidelity 2D photography — we present your project as a true sensory experience, seamlessly integrated into your website or delivered directly to your clients."
        data-panel-cta-label="Open Communication"
        data-panel-cta-href="{{ '/communication/' | toBaseRelative }}"
      >
        <rect class="hotspot-hitarea" x="518" y="244" width="202" height="126" />
        <rect class="hotspot-shape" x="548" y="250" width="124" height="76" />
        <rect class="hotspot-shape" x="560" y="261" width="100" height="54" />
        <path class="hotspot-shape" d="M544 328H676" />
        <path class="hotspot-shape" d="M524 334H696L682 354H538Z" />
        <path class="hotspot-shape" d="M551 341H669" />
        <path class="hotspot-shape" d="M560 347H660" />
        <g class="hotspot-tooltip" aria-hidden="true">
          <rect class="hotspot-tooltip-bg" x="545" y="216" width="130" height="24" rx="12" ry="12" />
          <text class="hotspot-tooltip-text" x="610" y="228" text-anchor="middle" dominant-baseline="middle" data-tooltip-text>
            Communication
          </text>
        </g>
      </g>

      <g
        id="hotspot-model"
        class="room-hotspot"
        role="button"
        tabindex="0"
        aria-label="Open Representation section"
        aria-controls="pillar-panel"
        aria-pressed="false"
        data-panel-title="REPRESENTATION"
        data-panel-body="We intervene on-site to capture your building with precision and sensitivity. Using advanced 3D scanning technologies, we provide a faithful, immersive, and atmosphere-driven digital restitution — ideal for renovation, design development, and communication."
        data-panel-cta-label="Open Representation"
        data-panel-cta-href="{{ '/representation/' | toBaseRelative }}"
      >
        <rect class="hotspot-hitarea" x="370" y="286" width="130" height="90" />
        <path class="hotspot-shape" d="M420 313L444 295L468 313V338H420Z" />
        <path class="hotspot-shape" d="M444 295L468 313L490 304L466 286Z" />
        <path class="hotspot-shape" d="M468 313V338L490 329V304Z" />
        <path class="hotspot-shape" d="M432 324H444" />
        <path class="hotspot-shape" d="M432 324V336" />
        <path class="hotspot-shape" d="M444 324V336" />
        <path class="hotspot-shape" d="M452 321H462" />
        <path class="hotspot-shape" d="M456 338V324" />
        <g class="hotspot-tooltip" aria-hidden="true">
          <rect class="hotspot-tooltip-bg" x="382" y="264" width="124" height="24" rx="12" ry="12" />
          <text class="hotspot-tooltip-text" x="444" y="276" text-anchor="middle" dominant-baseline="middle" data-tooltip-text>
            Representation
          </text>
        </g>
      </g>
    </svg>
  </div>
</section>

<div class="home-lang-switch home-lang-switch--room" role="group" aria-label="Language switch">
  <button class="home-lang-button is-active" type="button" data-lang="en" aria-pressed="true">EN</button>
  <button class="home-lang-button" type="button" data-lang="fr" aria-pressed="false">FR</button>
</div>

<div class="pillar-backdrop" id="panel-backdrop" hidden></div>
<aside
  class="pillar-panel"
  id="pillar-panel"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-labelledby="panel-title"
  hidden
>
  <button class="pillar-panel-close" id="panel-close" type="button" aria-label="Close panel">&times;</button>
  <div class="pillar-panel-content">
    <h2 class="pillar-panel-title" id="panel-title"></h2>
    <p class="pillar-panel-body" id="panel-body" hidden></p>
    <ul class="pillar-panel-points" id="panel-points"></ul>
    <a class="pillar-panel-cta" id="panel-cta" href="#">Open section</a>
  </div>
</aside>

<section class="home-contact home-contact--room" aria-label="Contact">
  <h2 data-i18n="contactTitle">Contact</h2>
  <p data-i18n="contactText">
    Have a project in mind or want to learn more about Archimmersion?
    Send us a note and we will get back to you.
  </p>
  <a class="contact-button" href="mailto:atiemichele@gmail.com" data-i18n="contactCta">Email Us</a>
  <p class="home-contact-location" aria-label="Location">Paris, France</p>
</section>
