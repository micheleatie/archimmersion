---
layout: layouts/base.njk
title: Home
description: Archimmersion homepage
bodyClass: home-page
---
<div id="top" class="top-anchor" aria-hidden="true"></div>

<section class="room-hero" aria-label="Homepage intro">
  <h1 class="room-hero-wordmark">ARCHIMMERSION</h1>
</section>

<section class="room-stage" data-room-scene aria-label="Interactive room metaphor">
  <div class="room-stage-headline" aria-hidden="true" data-i18n="headline">Explore the room.</div>
  <div class="room-svg-wrap">
    <svg
      class="room-svg"
      viewBox="0 0 1536 1024"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label="Architectural room with two interactive objects"
    >
      <g id="room-background">
        <image
          href="{{ '/assets/img/for-archimmersion.svg' | toBaseRelative }}"
          x="0"
          y="0"
          width="1536"
          height="1024"
          preserveAspectRatio="xMidYMid meet"
        />
      </g>
      <g
        id="hotspot-caption"
        class="room-hotspot"
        role="button"
        tabindex="0"
        aria-label="Open Data Capture and Restitution section"
        aria-controls="pillar-panel"
        aria-pressed="false"
        data-panel-title="DATA CAPTURE AND RESTITUTION"
        data-panel-body="We intervene on-site to capture your building with precision and sensitivity. Using advanced 3D scanning technologies, we provide a faithful, immersive, and atmosphere-driven digital restitution — ideal for renovation, design development, and communication."
        data-panel-cta-label="Open Data Capture and Restitution"
        data-panel-cta-href="{{ '/representation/' | toBaseRelative }}"
      >
        <g class="hotspot-hitlines" aria-hidden="true">
          <circle class="hotspot-hitline" cx="410" cy="438" r="38" />
          <path class="hotspot-hitline" d="M410 468L380 560M410 468L413 560M410 468L447 560" />
          <rect class="hotspot-hitline" x="795" y="198" width="370" height="195" rx="8" />
        </g>
        <g class="hotspot-shape" aria-hidden="true">
          <rect x="795" y="198" width="370" height="195" />
          <circle cx="410" cy="438" r="28" />
          <path d="M410 468L380 560M410 468L413 560M410 468L447 560" />
        </g>
        <g class="hotspot-tooltip" aria-hidden="true">
          <rect class="hotspot-tooltip-bg" x="812" y="172" width="252" height="24" rx="12" ry="12" />
          <text class="hotspot-tooltip-text" x="938" y="184" text-anchor="middle" dominant-baseline="middle" data-tooltip-text>
            Data Capture &amp; Restitution
          </text>
        </g>
        <g class="hotspot-tooltip" aria-hidden="true">
          <rect class="hotspot-tooltip-bg" x="262" y="374" width="252" height="24" rx="12" ry="12" />
          <text class="hotspot-tooltip-text" x="388" y="386" text-anchor="middle" dominant-baseline="middle" data-tooltip-text>
            Data Capture &amp; Restitution
          </text>
        </g>
      </g>

      <g
        id="hotspot-laptop"
        class="room-hotspot"
        role="button"
        tabindex="0"
        aria-label="Open Communication section"
        aria-controls="pillar-panel"
        aria-pressed="false"
        data-panel-title="COMMUNICATION"
        data-panel-body="Immersive Architectural Communication for professional websites and magazines. Beyond vision. We capture architecture as it is experienced. Through advanced imaging technologies and an expert eye for atmosphere, we translate spaces into immersive experiences — faithful, sensory, and atmospheric. Using cutting-edge tools — from 360° immersive environments to high-fidelity 2D photography — we present your project as a true sensory experience, seamlessly integrated into your website or delivered directly to your clients."
        data-panel-cta-label="Open Communication"
        data-panel-cta-href="{{ '/communication/' | toBaseRelative }}"
      >
        <g class="hotspot-hitlines" aria-hidden="true">
          <rect class="hotspot-hitline" x="760" y="390" width="690" height="370" rx="28" />
        </g>
        <g class="hotspot-shape" aria-hidden="true">
          <rect x="940" y="465" width="341" height="186" rx="12" />
          <rect x="963" y="486" width="295" height="130" />
          <path d="M930 651H1292L1318 690H903Z" />
          <path d="M957 652H1260" />
        </g>
        <g class="hotspot-tooltip" aria-hidden="true">
          <rect class="hotspot-tooltip-bg" x="1038" y="438" width="146" height="24" rx="12" ry="12" />
          <text class="hotspot-tooltip-text" x="1111" y="450" text-anchor="middle" dominant-baseline="middle" data-tooltip-text>
            Communication
          </text>
        </g>
      </g>
    </svg>
  </div>
</section>

<div class="home-lang-switch home-lang-switch--room" role="group" aria-label="Language switch">
  <button class="home-lang-button is-active" type="button" data-lang="en" aria-pressed="true">EN</button>
  <button class="home-lang-button" type="button" data-lang="fr" aria-pressed="false">FR</button>
</div>

<div class="pillar-backdrop" id="panel-backdrop" hidden></div>
<aside
  class="pillar-panel"
  id="pillar-panel"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-labelledby="panel-title"
  hidden
>
  <button class="pillar-panel-close" id="panel-close" type="button" aria-label="Close panel">&times;</button>
  <div class="pillar-panel-content">
    <h2 class="pillar-panel-title" id="panel-title"></h2>
    <p class="pillar-panel-body" id="panel-body" hidden></p>
    <ul class="pillar-panel-points" id="panel-points"></ul>
    <a class="pillar-panel-cta" id="panel-cta" href="#">Open section</a>
  </div>
</aside>

<section class="home-contact home-contact--room" aria-label="Contact">
  <h2 data-i18n="contactTitle">Contact</h2>
  <p data-i18n="contactText">
    Have a project in mind or want to learn more about Archimmersion?
    Send us a note and we will get back to you.
  </p>
  <a class="contact-button" href="mailto:michele.atie@archimmersion.fr" data-i18n="contactCta">Email Us</a>
  <p class="home-contact-location" aria-label="Location">Paris, France</p>
</section>
